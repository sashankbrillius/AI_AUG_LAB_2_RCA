{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "uid": "lab2-logs-rca",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Total HTTP requests per second to the RCA gateway",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"rca-gateway\"}[5m])) by (path)",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Endpoint",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "p95 and p50 response latency for the RCA gateway",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service=\"rca-gateway\"}[5m])) by (le))",
          "legendFormat": "Gateway p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{service=\"rca-gateway\"}[5m])) by (le))",
          "legendFormat": "Gateway p50",
          "refId": "B"
        }
      ],
      "title": "Gateway Latency (p50 / p95)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "RCA generation latency (p50 and p95)",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 15},
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 0},
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rca_generation_seconds_bucket{service=\"rca-gateway\"}[5m])) by (le))",
          "legendFormat": "RCA p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(rca_generation_seconds_bucket{service=\"rca-gateway\"}[5m])) by (le))",
          "legendFormat": "RCA p50",
          "refId": "B"
        }
      ],
      "title": "RCA Generation Latency",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Log lines ingested per source file",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 15},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 7},
      "id": 4,
      "targets": [
        {
          "expr": "sum(logs_ingested_total{service=\"rca-gateway\"}) by (source)",
          "legendFormat": "{{source}}",
          "refId": "A"
        }
      ],
      "title": "Logs Ingested by Source",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Log filter operations by severity level",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 15},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 7},
      "id": 5,
      "targets": [
        {
          "expr": "sum(logs_filtered_total{service=\"rca-gateway\"}) by (severity)",
          "legendFormat": "Filter: {{severity}}",
          "refId": "A"
        }
      ],
      "title": "Filter Operations by Severity",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "RCA reports generated by format and mode",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 15},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 7},
      "id": 6,
      "targets": [
        {
          "expr": "sum(rca_generated_total{service=\"rca-gateway\"}) by (format, mode)",
          "legendFormat": "{{format}} ({{mode}})",
          "refId": "A"
        }
      ],
      "title": "RCA Reports Generated",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Token usage — prompt vs completion",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 20, "stacking": {"mode": "normal"}},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 14},
      "id": 7,
      "targets": [
        {
          "expr": "sum(increase(llm_tokens_total{service=\"rca-gateway\",direction=\"prompt\"}[1h]))",
          "legendFormat": "Prompt tokens (1h)",
          "refId": "A"
        },
        {
          "expr": "sum(increase(llm_tokens_total{service=\"rca-gateway\",direction=\"completion\"}[1h]))",
          "legendFormat": "Completion tokens (1h)",
          "refId": "B"
        }
      ],
      "title": "Token Burn (Cost Proxy)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "HTTP 5xx error rate percentage",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 14},
      "id": 8,
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"rca-gateway\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{service=\"rca-gateway\"}[5m]))",
          "legendFormat": "Gateway 5xx %",
          "refId": "A"
        }
      ],
      "title": "Error Rate (5xx %)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Token burn rate per minute",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 15},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 14},
      "id": 9,
      "targets": [
        {
          "expr": "sum(rate(llm_tokens_total{service=\"rca-gateway\",direction=\"prompt\"}[5m])) * 60",
          "legendFormat": "Prompt tokens/min",
          "refId": "A"
        },
        {
          "expr": "sum(rate(llm_tokens_total{service=\"rca-gateway\",direction=\"completion\"}[5m])) * 60",
          "legendFormat": "Completion tokens/min",
          "refId": "B"
        }
      ],
      "title": "Token Burn Rate (per minute)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Total log lines currently stored in memory",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "blue", "value": null},
              {"color": "green", "value": 100}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 21},
      "id": 10,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "logs_store_total{service=\"rca-gateway\"}",
          "legendFormat": "Logs in Memory",
          "refId": "A"
        }
      ],
      "title": "Logs in Memory",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Total RCA reports generated",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "blue", "value": null},
              {"color": "green", "value": 1}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 21},
      "id": 11,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "sum(rca_generated_total{service=\"rca-gateway\"})",
          "legendFormat": "Total RCAs",
          "refId": "A"
        }
      ],
      "title": "Total RCA Reports",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Total LLM tokens consumed",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50000},
              {"color": "red", "value": 200000}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 21},
      "id": 12,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "sum(llm_tokens_total{service=\"rca-gateway\"})",
          "legendFormat": "Total Tokens",
          "refId": "A"
        }
      ],
      "title": "Total Tokens Used",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Current RCA cache size",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "blue", "value": null},
              {"color": "green", "value": 1}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 21},
      "id": 13,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "rca_cache_size{service=\"rca-gateway\"}",
          "legendFormat": "Cache Size",
          "refId": "A"
        }
      ],
      "title": "RCA Cache Entries",
      "type": "stat"
    }
  ],
  "refresh": "5s",
