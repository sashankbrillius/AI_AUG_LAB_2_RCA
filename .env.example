# OpenAI API Key (leave empty for mock mode — lab works fully without it)
OPENAI_API_KEY=""

# Model settings (used only in live mode)
OPENAI_MODEL=gpt-4o-mini

# Log filtering — which severity levels to include in RCA input
# Options: ALL | ERROR | WARN | ERROR,WARN | INFO,WARN,ERROR
LOG_FILTER_SEVERITY=ALL

# RCA output format — summary (brief) or detailed (full timeline + remediation)
RCA_OUTPUT_FORMAT=summary

# RCA generation mode: mock | llm
RCA_MODE=mock
